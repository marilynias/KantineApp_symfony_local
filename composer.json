{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "friendsofsymfony/rest-bundle": "^3.9",
        "jms/serializer-bundle": "*",
        "lexik/jwt-authentication-bundle": "3.*",
        "paragonie/sodium_compat": "^2.5",
        "phpdocumentor/reflection-docblock": "^6.0",
        "phpoffice/phpspreadsheet": "^5.4",
        "phpstan/phpdoc-parser": "^2.3",
        "picqer/php-barcode-generator": "^3.2",
        "sonata-project/admin-bundle": "^4.42",
        "sonata-project/doctrine-orm-admin-bundle": "^4.21",
        "sonata-project/user-bundle": "^5.19",
        "symfony/asset": "*",
        "symfony/asset-mapper": "*",
        "symfony/console": "*",
        "symfony/dotenv": "*",
        "symfony/flex": "*",
        "symfony/form": "*",
        "symfony/framework-bundle": "*",
        "symfony/mime": "*",
        "symfony/monolog-bundle": "^4.0",
        "symfony/polyfill-intl-messageformatter": "*",
        "symfony/property-access": "*",
        "symfony/property-info": "*",
        "symfony/runtime": "*",
        "symfony/security-bundle": "*",
        "symfony/serializer": "*",
        "symfony/translation": "*",
        "symfony/twig-bundle": "*",
        "symfony/ux-twig-component": "*",
        "symfony/validator": "*",
        "symfony/yaml": "*",
        "twig/extra-bundle": "^2.12|^3.0",
        "twig/twig": "^2.12|^3.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "Shared\\": "src/",
            "Kantine\\": "apps/kantine/src/",
            "Zeiterfassung\\": "apps/zeiterfassung/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Shared\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*"
    },
    "scripts": {
        "auto-scripts": {
            "importmap:install -ikantine": "symfony-cmd",
            "importmap:install -izeiterfassung": "symfony-cmd",
            "cache:clear -ikantine": "symfony-cmd",
            "cache:clear -izeiterfassung": "symfony-cmd",
            "assets:install %PUBLIC_DIR% -ikantine": "symfony-cmd",
            "assets:install %PUBLIC_DIR% -izeiterfassung --no-cleanup": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.*"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3",
        "icanhazstring/composer-unused": "^0.9.5",
        "phpunit/phpunit": "^13.1",
        "symfony/browser-kit": "*",
        "symfony/css-selector": "*",
        "symfony/debug-bundle": "*",
        "symfony/maker-bundle": "*",
        "symfony/stopwatch": "*",
        "symfony/web-profiler-bundle": "*"
    }
}
